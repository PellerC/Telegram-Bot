TELEGRAM_BOT_TOKEN=

# Optional. If omitted, the bot uses a deterministic keyword parser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: connect an existing agent backend to Telegram.
# The bot POSTs user messages here and uses the returned reply.
AGENT_WEBHOOK_URL=
AGENT_WEBHOOK_SECRET=

# Used to encrypt/decrypt burner wallets on the server.
# Generate with: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=

# Local MVP storage. Keep this out of git in real deployments.
DATA_FILE=.data/bot-store.json

# Production storage for public users. If set, the bot uses PostgreSQL instead of DATA_FILE.
DATABASE_URL=
